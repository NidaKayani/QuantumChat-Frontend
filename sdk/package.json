{
  "name": "@quantum-chat/sdk",
  "version": "1.0.0",
  "description": "JavaScript SDK for embedding Quantum Chat via script tag",
  "main": "dist/quantum-chat-sdk.umd.js",
  "module": "dist/quantum-chat-sdk.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/quantum-chat-sdk.es.js",
